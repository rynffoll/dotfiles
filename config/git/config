# -*- mode: gitconfig -*-
[user]
	name = Ruslan Kamashev
	email = rynffoll@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub

[gpg]
	format = ssh

[gpg "ssh"]
	# ./scripts/gen_ssh_allowed_signers.sh
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign = true

[includeIf "gitdir:~/Projects/work/"]
	path = "~/Projects/work/.gitconfig"

# https://github.com/j178/prek/blob/master/docs/cookbook.md#enable-a-global-hook-with-git-config
[hook "prek-pre-commit"]
	event = pre-commit
	command = prek hook-impl --hook-type pre-commit --skip-on-missing-config --
